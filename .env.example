# Copy this file to .env and fill in your actual keys.
# Never commit the real .env file.

# --- Alpaca (Market Data Agent) ---
ALPACA_API_KEY=your_alpaca_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_here

# --- Financial Modeling Prep (Research Agent) ---
FMP_API_KEY=your_fmp_key_here

# --- Webull OpenAPI (Portfolio Agent) ---
# Reuse the same values already configured for webull-openapi-mcp so this
# project shares the existing authenticated token instead of re-triggering 2FA.
WEBULL_APP_KEY=your_webull_app_key_here
WEBULL_APP_SECRET=your_webull_app_secret_here
WEBULL_REGION_ID=us
WEBULL_ENVIRONMENT=prod
WEBULL_TOKEN_DIR=C:\Users\ksher\.webull-mcp\conf

# --- Anthropic (Decision Agent) ---
ANTHROPIC_API_KEY=your_anthropic_key_here

# --- Universe ---
UNIVERSE_CSV_PATH=data/universe.csv
